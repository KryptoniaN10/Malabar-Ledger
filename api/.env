# Malabar Ledger — .env (testnet, no real keys needed for demo)
# Copy this to api/.env and frontend/.env as well, or run setup-testnet.sh

STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Issuer / Admin — generate with: soroban keys generate ml-issuer --network testnet
# Leave blank for demo-mode (API works without these for the UI demo flow)
ISSUER_PUBLIC_KEY=
ISSUER_SECRET_KEY=

# Oracle (confirms payments) — same as admin for demo
ORACLE_PUBLIC_KEY=
ORACLE_SECRET_KEY=

# Contract IDs — populated by deploy-contracts.sh
# Leave blank until Soroban contracts are deployed
RECEIVABLE_REGISTRY_CONTRACT_ID=
FRACTIONAL_SALE_CONTRACT_ID=
SETTLEMENT_ESCROW_CONTRACT_ID=

# API server
PORT=3001
DATABASE_URL=../malabar.db

# IPFS — optional. Without keys, API runs in hash-only mode
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Frontend
VITE_API_URL=http://192.168.20.78:3001
VITE_STELLAR_NETWORK=testnet
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
